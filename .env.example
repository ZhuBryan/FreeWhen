# Supabase project settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — SERVER ONLY. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used to build shareable group links.
# Local dev: http://localhost:3000  ·  Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Live sync (optional). Same project URL as above plus the *anon/public* key —
# used only for realtime broadcast subscriptions in the browser. If unset, the
# app falls back to refetch-on-focus.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
